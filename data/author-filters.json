      {"name": "Hiim_Crafting_Druid_Focused.filter", "displayName": "Class — Druid", "description": "Class filter tuned for Druid. Shows Druid-relevant items and crafting bases at higher filter levels.", "url": "https://raw.githubusercontent.com/Maaaaaarrk/HiimFilter-PD2-Filter/main/Hiim_Crafting_Druid_Focused.filter", "size": 485717},
